{
  "name": "tree-presence",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=packages/server",
    "dev:frontend": "npm run dev --workspace=packages/frontend",
    "build": "npm run build --workspace=packages/agent && npm run build --workspace=packages/server",
    "build:frontend": "npm run build --workspace=packages/frontend"
  }
}
